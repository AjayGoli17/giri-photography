document.addEventListener('DOMContentLoaded', () => {

  /* ---------- Services carousel ---------- */
  const services = [
    { label: 'Wedding',        image: 'https://picsum.photos/seed/giri-wedding/700/900',   title: 'Wedding & Pre-Wedding',       price: '₹8,000' },
    { label: 'Maternity',      image: 'https://picsum.photos/seed/giri-maternity/700/900',  title: 'Maternity Shoot',             price: '₹6,500' },
    { label: 'House Warming',  image: 'https://picsum.photos/seed/giri-housewarming/700/900', title: 'House Warming Ceremony',    price: '₹5,000' },
    { label: 'Portrait',       image: 'https://picsum.photos/seed/giri-portrait/700/900',   title: 'Portrait & Editorial',        price: '₹4,000' },
    { label: 'Baby Shoot',     image: 'https://picsum.photos/seed/giri-baby/700/900',       title: 'Newborn & Baby Shoot',        price: '₹5,500' },
    { label: 'Event Coverage', image: 'https://picsum.photos/seed/giri-event/700/900',      title: 'Event & Corporate Coverage',  price: '₹7,000' }
  ];

  const serviceCardsContainer = document.querySelector('.service-cards');

  function renderServices() {
    if (!serviceCardsContainer) return;
    serviceCardsContainer.innerHTML = services.map((data, i) => `
      <div class="service-card">
        <div class="ph" style="background-image:url('${data.image}');" data-label="${data.label}"></div>
        <div class="count">0${i + 1} / ${services.length}</div>
        <h3>${data.title}</h3>
        <div class="price">${data.price}</div>
      </div>
    `).join('');
  }


  renderServices();

  /* ---------- Services swipe hint ---------- */
  const scrollHint = document.querySelector('.scroll-hint');

  if (serviceCardsContainer) {
    serviceCardsContainer.addEventListener('scroll', () => {
      if (scrollHint) scrollHint.classList.add('hidden');
    }, { passive: true });
  }

  /* ---------- Service cards alternating reveal (odd up, even down) ---------- */
  try {
    const serviceCardEls = document.querySelectorAll('.service-card');

    if ('IntersectionObserver' in window && serviceCardEls.length) {
      // Only hide cards once we know we can reveal them again — keeps
      // the section visible by default if anything below throws.
      serviceCardEls.forEach((card, i) => {
        card.classList.add('pre-reveal', i % 2 === 0 ? 'reveal-up' : 'reveal-down');
      });

      const cardObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            entry.target.classList.remove('pre-reveal');
            cardObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });

      serviceCardEls.forEach(card => cardObserver.observe(card));
    }
    // If IntersectionObserver isn't supported, cards stay in their
    // normal, fully visible state — no fallback class needed.
  } catch (err) {
    console.error('Service card reveal animation failed:', err);
  }

  /* ---------- Quote carousel ---------- */
  const quotes = [
    { text: 'The studio has a unique ability to capture the soul of a garment. Their work isn\u2019t just photography; it\u2019s high art that communicates prestige and quiet luxury.', cite: 'Creative Director, Vogue' },
    { text: 'Every frame felt intentional. It didn\u2019t just document our wedding day, it told the story we\u2019ll want to remember in twenty years.', cite: 'Priya & Arjun, Clients' },
    { text: 'Working with this team on our editorial shoot was effortless. They understood the brief instantly and elevated it further.', cite: 'Art Director, Elle India' }
  ];

  let quoteIndex = 0;
  const quoteEl = document.querySelector('.quote-section blockquote');
  const citeEl = document.querySelector('.quote-section cite');
  const dotsEl = document.querySelector('.quote-section .quote-dots');
  const QUOTE_INTERVAL = 2500; // ms between auto-advances
  const QUOTE_FADE = 350;      // ms fade duration, keep in sync with CSS transition

  function renderDots() {
    if (!dotsEl) return;
    dotsEl.innerHTML = quotes.map((_, i) =>
      `<button type="button" class="quote-dot${i === quoteIndex ? ' active' : ''}" aria-label="Show testimonial ${i + 1} of ${quotes.length}" data-index="${i}"></button>`
    ).join('');
  }

  function renderQuote() {
    if (!quoteEl || !citeEl) return;
    quoteEl.style.opacity = 0;
    citeEl.style.opacity = 0;
    setTimeout(() => {
      quoteEl.textContent = `\u201C${quotes[quoteIndex].text}\u201D`;
      citeEl.textContent = `\u2014 ${quotes[quoteIndex].cite}`;
      quoteEl.style.opacity = 1;
      citeEl.style.opacity = 1;
      renderDots();
    }, QUOTE_FADE);
  }

  function advanceQuote() {
    quoteIndex = (quoteIndex + 1) % quotes.length;
    renderQuote();
  }

  if (quoteEl && citeEl && quotes.length > 1) {
    renderDots();

